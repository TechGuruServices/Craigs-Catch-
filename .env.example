# Required: Your PostgreSQL / SQLite database path or connection string
DATABASE_URL=./local.db

PORT=5000

# Groq AI (get a free key at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
MODEL_NAME=llama3-8b-8192

# Optional: How often the server checks for new RSS items in minutes (Defaults to 10)
CHECK_INTERVAL_MINUTES=10

# Telegram Notification Settings (Optional)
# Get a token from @BotFather on Telegram, and your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

