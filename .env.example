# Required: Your SQLite database file path
DATABASE_URL=./local.db

PORT=5000

# Optional: The URL to your Ollama instance (Defaults to http://localhost:11434/api/chat)
OLLAMA_URL=http://localhost:11434/api/chat

# Optional: The specific Ollama model to use (Defaults to qwen)
OLLAMA_MODEL=qwen

# Optional: How often the server checks for new RSS items in minutes (Defaults to 15)
CHECK_INTERVAL_MINUTES=15
# Telegram Notification Settings (Optional)
# Get a token from @BotFather on Telegram, and your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=-100xxxxxxxxxx
